# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env.local
.env
.env.old
.env.local.old

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

python-service/.checkpoints
python-service/.cache
python-service/__pycache__/
python-service/venv*/
python-service/timesfm/venv*/
venv*/
timesfm/
**/__pycache__/
*.pyc
# Kalshi UI-uploaded credentials (never commit)
.kalshi-credentials.json

# Persistent trade log (local algo data, not for VCS)
data/trade-log.json
data/agent-config.json

# Python service runtime cache/output (generated at runtime)
python-service/_backtest_cache_*.json
python-service/live_analysis_cache.json
python-service/live_analysis_results.json
python-service/live_fills.json
python-service/research_cache.json

.sentient-trader/config.env

# Python daemon logs
python-service/logs/

# Python service research outputs
python-service/research/

# sentient-trader-mcp build artifacts
sentient-trader-mcp/dist/
sentient-trader-mcp/*.egg-info/

# Dev/scratch scripts
python-service/backtest_67c.py
python-service/test_tiered_kelly.py
.vs/slnx.sqlite
.vs/**

python-service/tests/test_trade_daemon_order_status.py
